# ========================================
# wawa_smart_erp .gitignore
# ========================================

# ── Dependencies ──
node_modules/
jspm_packages/
.yarn/

# ── Build artifacts ──
dist/
build/
.next/
.nuxt/
.vite/
.serverless/

# ── Logs ──
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ── Editor / OS ──
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ========================================
# SECRETS & ENVIRONMENT (최우선 보호)
# ========================================
.env
.env.*
!.env.example
.dev.vars
workers/.dev.vars

# ── Cloudflare Wrangler (로컬 D1/KV/R2 데이터 + 계정 정보) ──
.wrangler/
workers/.wrangler/

# ── E2E test config (API keys 포함 가능) ──
apps/desktop/e2e/test-config.json

# ========================================
# E2E TEST ARTIFACTS
# ========================================
test-results/
**/test-results/
**/playwright-report/
**/html-report/
**/.playwright/
apps/desktop/e2e-report/
apps/desktop/e2e-screenshots/
apps/desktop/e2e-usecase-screenshots/

# ========================================
# APP-SPECIFIC
# ========================================

# ── Desktop app (legacy Electron + Python backend 제거됨) ──
apps/desktop/release/
apps/desktop/backend/
apps/desktop/backend.log
apps/desktop/assets/
apps/desktop/shared/
apps/desktop/e2e-report/
apps/desktop/e2e-screenshots-all/
apps/desktop/e2e-screenshots-makeup-dm/
apps/desktop/ppt-screenshots/
apps/desktop/test-downloads/
apps/desktop/coverage/

# ── Student app ──
apps/student/dist/

# ── 개인정보 보호 ──
backup/
reports/
apps/reports/
uploads/
processed/

# ── Notion config (API key 포함) ──
notion_config.json

# ── Scripts (개인 데이터 포함 가능) ──
scripts/

# ========================================
# BINARY / DOCUMENT FILES
# ========================================
*.pptx
*.docx
*.pdf
*.pid
*.seed
*.patch

# ── Images (소스 로고 등) ──
*.png
*.jpg
*.jpeg
*.gif
/app_logo.jpg
/wawa_logo.jpg
**/assets/**/*.pdf
**/assets/**/*.png
**/assets/**/*.jpg
**/assets/**/*.jpeg
**/assets/**/*.gif

# ========================================
# TEST DATA / SEED — 실명·PIN 해시·테스트 DB 자격증명 포함. 절대 커밋 금지
# ========================================
workers/migrations/seed_test_fixtures.sql
workers/migrations/seed_*.sql
workers/seed-*.sql
workers/seed-*.mjs
workers/.dev.vars
workers/.dev.vars.*
.env
.env.*
!.env.example

# ========================================
# MISC
# ========================================
.nyc_output/
/coverage/
.cache/
.eslintcache
/storybook-static/
code*.html

# ── Debug / scratch artifacts ──
debug-screenshots/
workers/debug-screenshots/
e2e-results.txt
workers/e2e-results.txt
db_schema_debug.json
check-console.js
check-console.cjs
workers/check-console.js
workers/check-console.cjs
workers/STATUS.txt
*.tsbuildinfo

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
venv/
.venv/
ENV/
env/
*.egg-info/
.eggs/
