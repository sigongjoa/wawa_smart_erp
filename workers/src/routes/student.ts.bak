import { Router } from 'itty-router';
import { RequestContext, Student } from '@/types';
import { executeQuery, executeFirst, executeInsert, executeUpdate, executeDelete } from '@/utils/db';
import { successResponse, errorResponse, unauthorizedResponse, notFoundResponse } from '@/utils/response';
import { requireAuth, requireRole } from '@/middleware/auth';

export const studentRouter = Router<RequestContext>();

// 학생 목록 조회
studentRouter.get('/', async (context: RequestContext) => {
  try {
    if (!requireAuth(context)) return unauthorizedResponse();

    const classId = context.request.url.split('?')[1]?.split('=')[1];
    let query = 'SELECT * FROM students WHERE academy_id = ? ORDER BY name';
    let params: any[] = [context.auth!.academyId];

    if (classId) {
      query = 'SELECT * FROM students WHERE academy_id = ? AND class_id = ? ORDER BY name';
      params = [context.auth!.academyId, classId];
    }

    const students = await executeQuery<Student>(context.env.DB, query, params);

    return successResponse(students);
  } catch (error) {
    console.error('Get students error:', error);
    return errorResponse('Failed to get students', 500);
  }
});

// 학생 상세 조회
studentRouter.get('/:id', async (context: RequestContext) => {
  try {
    if (!requireAuth(context)) return unauthorizedResponse();

    const { id } = context.params;

    const student = await executeFirst<Student>(
      context.env.DB,
      'SELECT * FROM students WHERE id = ? AND academy_id = ?',
      [id, context.auth!.academyId]
    );

    if (!student) return notFoundResponse();

    return successResponse(student);
  } catch (error) {
    console.error('Get student error:', error);
    return errorResponse('Failed to get student', 500);
  }
});

// 학생 추가
studentRouter.post('/', async (context: RequestContext) => {
  try {
    if (!requireAuth(context) || !requireRole(context, 'instructor', 'admin')) {
      return unauthorizedResponse();
    }

    const { name, classId, contact, guardianContact, enrollmentDate } = await context.request.json() as any;

    if (!name) {
      return errorResponse('Student name is required', 400);
    }

    const id = crypto.randomUUID();
    const result = await executeInsert(
      context.env.DB,
      `INSERT INTO students (id, academy_id, name, class_id, contact, guardian_contact, enrollment_date, status, created_at, updated_at)
       VALUES (?, ?, ?, ?, ?, ?, ?, ?, datetime('now'), datetime('now'))`,
      [
        id,
        context.auth!.academyId,
        name,
        classId || null,
        contact,
        guardianContact,
        enrollmentDate || new Date().toISOString().split('T')[0],
        'active',
      ]
    );

    if (!result.success) {
      return errorResponse('Failed to create student', 500);
    }

    const student = await executeFirst<Student>(
      context.env.DB,
      'SELECT * FROM students WHERE id = ?',
      [id]
    );

    return successResponse(student, 201);
  } catch (error) {
    console.error('Create student error:', error);
    return errorResponse('Failed to create student', 500);
  }
});

// 학생 정보 수정
studentRouter.patch('/:id', async (context: RequestContext) => {
  try {
    if (!requireAuth(context) || !requireRole(context, 'instructor', 'admin')) {
      return unauthorizedResponse();
    }

    const { id } = context.params;
    const { name, classId, contact, guardianContact, status } = await context.request.json() as any;

    const student = await executeFirst(
      context.env.DB,
      'SELECT * FROM students WHERE id = ? AND academy_id = ?',
      [id, context.auth!.academyId]
    );

    if (!student) return notFoundResponse();

    const updates = [];
    const values = [];

    if (name !== undefined) {
      updates.push('name = ?');
      values.push(name);
    }
    if (classId !== undefined) {
      updates.push('class_id = ?');
      values.push(classId);
    }
    if (contact !== undefined) {
      updates.push('contact = ?');
      values.push(contact);
    }
    if (guardianContact !== undefined) {
      updates.push('guardian_contact = ?');
      values.push(guardianContact);
    }
    if (status !== undefined) {
      updates.push('status = ?');
      values.push(status);
    }

    if (updates.length === 0) {
      return errorResponse('No fields to update', 400);
    }

    updates.push('updated_at = datetime("now")');
    values.push(id);

    const result = await executeUpdate(
      context.env.DB,
      `UPDATE students SET ${updates.join(', ')} WHERE id = ?`,
      values
    );

    if (!result) {
      return errorResponse('Failed to update student', 500);
    }

    const updated = await executeFirst<Student>(
      context.env.DB,
      'SELECT * FROM students WHERE id = ?',
      [id]
    );

    return successResponse(updated);
  } catch (error) {
    console.error('Update student error:', error);
    return errorResponse('Failed to update student', 500);
  }
});

// 학생 삭제
studentRouter.delete('/:id', async (context: RequestContext) => {
  try {
    if (!requireAuth(context) || !requireRole(context, 'admin')) {
      return unauthorizedResponse();
    }

    const { id } = context.params;

    const student = await executeFirst(
      context.env.DB,
      'SELECT * FROM students WHERE id = ? AND academy_id = ?',
      [id, context.auth!.academyId]
    );

    if (!student) return notFoundResponse();

    const result = await executeDelete(
      context.env.DB,
      'DELETE FROM students WHERE id = ?',
      [id]
    );

    if (!result) {
      return errorResponse('Failed to delete student', 500);
    }

    return successResponse({ message: 'Student deleted successfully' });
  } catch (error) {
    console.error('Delete student error:', error);
    return errorResponse('Failed to delete student', 500);
  }
});
