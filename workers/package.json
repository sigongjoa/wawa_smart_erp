{
  "name": "wawa-smart-erp-api",
  "version": "1.0.0",
  "description": "WAWA Smart ERP - Cloudflare Workers API",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "db:migrate": "wrangler d1 migrations create wawa-smart-erp init",
    "db:apply": "wrangler d1 execute wawa-smart-erp --file=./migrations/001_init.sql"
  },
  "dependencies": {
    "itty-router": "^4.1.2",
    "jose": "^5.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250408.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.0.0",
    "playwright": "^1.59.1",
    "typescript": "^5.3.0",
    "vitest": "^4.1.3",
    "wrangler": "^3.82.0"
  }
}
