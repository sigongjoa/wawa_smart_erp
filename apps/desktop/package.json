{
  "name": "wawa-smart-erp",
  "version": "1.6.6",
  "description": "WAWA Smart ERP - 통합 학원 관리 시스템",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/sigongjoa/wawa_smart_erp.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && npx wrangler pages deploy dist/renderer",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "npx ts-node e2e/generate-pdf-report.ts"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^28.0.0",
    "playwright": "^1.59.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^4.0.18",
    "wrangler": "^3.0.0"
  }
}
